# Optional: require this value in the X-API-Key header on every request.
# Leave unset for unauthenticated local development.
EDGEVAL_API_KEY=

# Requests allowed per identity (API key, or client IP if no key) per 60s window.
EDGEVAL_RATE_LIMIT=20

# Where uploaded models/datasets and the SQLite DB are stored.
DATA_DIR=/app/data

# Optional: enables the LLM-generated narrative summary layered on top of
# the report. The pass/fail verdict stays rule-based regardless of this —
# leave unset to skip the AI Insights section entirely.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Comma-separated origins allowed to call this API, e.g. your Vercel frontend:
# ALLOWED_ORIGINS=https://edgeval.vercel.app
# Defaults to "*" (any origin) if unset — fine for local dev, restrict in production.
ALLOWED_ORIGINS=*
